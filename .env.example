# HR 戰略快報 — Power Automate 私訊 Webhook（必填，含 sig=）
# HR_TEAMS_WEBHOOK_URL=

# 選填：第二位收件人獨立流程 URL
# HR_TEAMS_WEBHOOK_URL_EXTRA=

# AI 生成（HR 快報預設使用 Gemini，與 morning-bot 分開計費）
# GEMINI_API_KEY=

# AI_PROVIDER=gemini
# GEMINI_MODEL=gemini-3.5-flash

# 若改用 OpenAI：
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini

# USE_AI=true
# DRY_RUN=true
